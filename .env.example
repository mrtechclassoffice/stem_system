APP_NAME="STEM Academy LMS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=stem_lms
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

SELECT_LOG_CHANNEL=stack
LOG_LEVEL=debug

FILESYSTEM_DISK=public

# Mail Configuration (Gmail SMTP - use App Password)
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-gmail@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@stem.local"
MAIL_FROM_NAME="${APP_NAME}"

# Admin Default Credentials (for seeder)
ADMIN_EMAIL=admin@stem.local
ADMIN_PASSWORD=Admin@1234
